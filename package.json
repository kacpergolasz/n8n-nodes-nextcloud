{
	"name": "n8n-nodes-nextcloud",
	"version": "0.1.0",
	"description": "Nextcloud suite community nodes for n8n — WIP",
	"license": "MIT",
	"homepage": "https://github.com/kacpergolasz/n8n-nodes-monorepo/tree/main/packages/nextcloud",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "kacpergolasz",
		"email": "kgolasz@outlook.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/kacpergolasz/n8n-nodes-monorepo.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"lint:safety": "eslint -c eslint.safety.config.mjs .",
		"test": "vitest run",
		"release": "n8n-node release",
		"prepublishOnly": "npm run lint:safety && n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/NextcloudApi.credentials.js",
			"dist/credentials/NextcloudOAuth2Api.credentials.js"
		],
		"nodes": [
			"dist/nodes/NextcloudCalendar/NextcloudCalendar.node.js",
			"dist/nodes/NextcloudDeck/NextcloudDeck.node.js",
			"dist/nodes/NextcloudFiles/NextcloudFiles.node.js",
			"dist/nodes/NextcloudFilesTrigger/NextcloudFilesTrigger.node.js",
			"dist/nodes/NextcloudNews/NextcloudNews.node.js",
			"dist/nodes/NextcloudNewsTrigger/NextcloudNewsTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.9.6",
		"release-it": "20.2.1",
		"typescript": "6.0.3",
		"vitest": "^3.2.7",
		"zod": "^3.25.67"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
